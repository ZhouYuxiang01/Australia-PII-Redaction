{
  "policy_id": "opf-v3-default-v1",
  "description": "Default policy for OPF v3 73-class. type_actions are calibration-informed: high-risk under-redaction classes default to REVIEW. Per-type thresholds are dev-calibrated and ready for confidence-based override when the backend exposes calibrated confidence.",
  "model_version": "opf-73class-v3-full",
  "taxonomy_version": "taxonomy_v1.1.1-draft-73class",
  "schema_version": "redaction-output-v1",
  "redaction_mode": "replace_with_tag",
  "redact_review_types": [
    "PHONE",
    "USI",
    "STUDENT_ID",
    "PAYMENT_CARD_NUMBER",
    "CREDIT_CARD_CVV",
    "AU_BANK_ACCOUNT",
    "AU_TFN",
    "MEDICARE_NUMBER",
    "VEHICLE_ID",
    "AU_DRIVERS_LICENCE",
    "USERNAME",
    "SOCIAL_MEDIA_ID"
  ],
  "default_action": "AUTO_REDACT",
  "confidence": {
    "calibrated": true,
    "default_value": null,
    "aggregation": "mean_exp_token_logprob",
    "note": "Per-span confidence computed at runtime by the OpfBackend (mean exp(logprob) over overlapping tokens). When confidence is non-null, type_thresholds drive AUTO_REDACT/REVIEW/PASS via core.policy.apply_policy."
  },
  "global_block_threshold": 0.7699,
  "global_review_threshold": 0.5605,
  "calibration": {
    "source": "runs/final/opf_73class_v3_full/dev_with_logprobs/thresholds_dev.json",
    "calibration_set": "data_opf_v2b/dev.jsonl (7100 in-distribution examples)",
    "block_precision_floor": 0.98,
    "review_recall_floor": 0.95,
    "ECE_dev_global": 0.0135
  },
