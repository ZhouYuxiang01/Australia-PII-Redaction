  "postprocess": {
    "strip_known_prefixes": true,
    "collapse_generic_work_contacts": true,
    "add_url_encoded_emails": true,
    "benchmark_dob_variants": false
  },
  "overlap_resolution": {
    "strategy": "keep_longer_then_earlier",
    "note": "When spans overlap after post-processing, keep the longer span; ties keep the earlier span."
  }
}
