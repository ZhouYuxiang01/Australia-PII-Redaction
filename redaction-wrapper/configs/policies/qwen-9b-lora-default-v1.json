  "type_actions": {
    "PERSON": "AUTO_REDACT",
    "ADDRESS": "AUTO_REDACT",
    "DATE_OF_BIRTH": "AUTO_REDACT",
    "EMAIL_ADDRESS": "AUTO_REDACT",
    "AU_PHONE": "AUTO_REDACT",
    "AU_TFN": "AUTO_REDACT",
    "AU_PASSPORT": "AUTO_REDACT",
    "AU_DRIVERS_LICENCE": "AUTO_REDACT",
    "STUDENT_ID": "AUTO_REDACT",
    "MEDICARE_NUMBER": "AUTO_REDACT",
    "AU_BANK_ACCOUNT": "AUTO_REDACT",
    "BSB": "AUTO_REDACT",
    "PAYMENT_CARD_NUMBER": "AUTO_REDACT",
    "IP_ADDRESS": "AUTO_REDACT",
    "VEHICLE_REGO": "AUTO_REDACT",
    "SALARY": "REVIEW",
    "WORK_EMAIL": "AUTO_REDACT",
    "WORK_PHONE": "AUTO_REDACT",
    "EMPLOYEE_NUMBER": "AUTO_REDACT",
    "PERSONNEL_NUMBER": "AUTO_REDACT",
    "MEDICARE_EXPIRY": "AUTO_REDACT",
